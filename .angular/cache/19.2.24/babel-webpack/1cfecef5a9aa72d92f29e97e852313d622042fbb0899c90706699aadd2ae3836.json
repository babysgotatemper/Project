{"ast":null,"code":"import * as i0 from \"@angular/core\";\nimport * as i1 from \"@angular/material/sidenav\";\nexport let GitComponent = /*#__PURE__*/(() => {\n  class GitComponent {\n    constructor() {}\n    ngOnInit() {}\n    static {\n      this.ɵfac = function GitComponent_Factory(__ngFactoryType__) {\n        return new (__ngFactoryType__ || GitComponent)();\n      };\n    }\n    static {\n      this.ɵcmp = /*@__PURE__*/i0.ɵɵdefineComponent({\n        type: GitComponent,\n        selectors: [[\"app-git\"]],\n        standalone: false,\n        decls: 84,\n        vars: 0,\n        consts: [[\"hasBackdrop\", \"true\", 1, \"example-container\"], [\"data-parallax\", \"true\", 1, \"page-header\", \"header-filter\", 2, \"background-image\", \"url('assets/img/git.jpg')\"], [1, \"main\", \"main-raised\"], [1, \"container\"], [1, \"section\", \"text-center\"], [1, \"title\"], [1, \"list\"], [1, \"list-title\"], [\"href\", \"https://githowto.com/\", \"target\", \"_blank\"], [1, \"code\"], [1, \"fa\", \"fa-github-square\"], [\"href\", \"https://github.com/\", \"target\", \"_blank\"], [1, \"fa\", \"fa-check-circle\"]],\n        template: function GitComponent_Template(rf, ctx) {\n          if (rf & 1) {\n            i0.ɵɵelementStart(0, \"mat-drawer-container\", 0)(1, \"mat-drawer-content\");\n            i0.ɵɵelement(2, \"div\", 1);\n            i0.ɵɵelementStart(3, \"div\", 2)(4, \"div\", 3)(5, \"div\", 4)(6, \"h2\", 5);\n            i0.ɵɵtext(7, \"GIT\");\n            i0.ɵɵelementEnd();\n            i0.ɵɵelementStart(8, \"h3\");\n            i0.ɵɵtext(9, \"\\u0420\\u043E\\u0437\\u043F\\u043E\\u0434\\u0456\\u043B\\u0435\\u043D\\u0430 \\u0441\\u0438\\u0441\\u0442\\u0435\\u043C\\u0430 \\u043A\\u0435\\u0440\\u0443\\u0432\\u0430\\u043D\\u043D\\u044F \\u0432\\u0435\\u0440\\u0441\\u0456\\u044F\\u043C\\u0438 \\u0444\\u0430\\u0439\\u043B\\u0456\\u0432 \\u0442\\u0430 \\u0441\\u043F\\u0456\\u043B\\u044C\\u043D\\u043E\\u0457 \\u0440\\u043E\\u0431\\u043E\\u0442\\u0438\");\n      